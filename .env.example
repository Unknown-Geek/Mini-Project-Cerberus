# =====================================================
# Cerberus Backend Configuration
# =====================================================
# Copy this file to .env and update with your values

# n8n Webhook URL - Your AI vulnerability analysis endpoint
N8N_WEBHOOK_URL=https://your-n8n-instance/webhook/scan

# Request timeout in seconds
N8N_TIMEOUT_SECONDS=120

# Backend server port (5000 for local, 7860 for HF Spaces)
PORT=5000

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Max characters per n8n call. Files larger than this are split into chunks
# to stay within reverse-proxy timeout limits (e.g. nginx default 60s).
MAX_CHUNK_CHARS=1500

# Lines of already-corrected code prepended to each chunk as context,
# so the AI understands mid-file continuations.
OVERLAP_LINES=5

# =====================================================
# Hugging Face Spaces Deployment
# =====================================================
# If you deployed to HF Spaces (https://huggingface.co/spaces/YOUR-USERNAME/Cerberus),
# configure these environment variables in your Space settings instead of this file:
#
# Required secrets:
# - N8N_WEBHOOK_URL (your n8n webhook)
# - N8N_TIMEOUT_SECONDS (120)
# - PORT (7860)
#
# Then configure your VS Code extension:
# Settings > Cerberus: Backend Url = https://YOUR-USERNAME-cerberus.hf.space

