# Exclude sensitive / dev-only files
.env
.env.example
.git
.gitignore
.DS_Store

# Source TypeScript (compiled JS is in out/)
src/**/*.ts
!src/**/*.d.ts

# Server is run separately — not part of the packaged extension
server/

# Test / dev files
scan_test.js
test_vulnerable.py
test_vulnerable_fixed.py
server/test/

# Workflow / config not needed at runtime
Main Workflow.json
eslint.config.mjs
tsconfig.json

# Dev-only node_modules
node_modules/.cache
node_modules/**/*.md
node_modules/**/*.ts
!node_modules/**/*.d.ts
node_modules/**/test/
node_modules/**/tests/
node_modules/**/.github

